<UserControl x:Class="HelloID.Vault.Management.Views.ReferenceData.CustomFieldDataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1400"
             Loaded="OnLoaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Panel -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                Padding="16"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title Section -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="{Binding TableDisplayName}"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding TotalRecords, StringFormat='{}{0} records'}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{Binding ActiveFilterCount, StringFormat=' ({0} filters active)'}"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                                   Visibility="{Binding ActiveFilterCount, Converter={StaticResource CountToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Search -->
                <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:AutoSuggestBox PlaceholderText="Search..."
                                       Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       QueryIcon="Find"
                                       VerticalAlignment="Center"
                                       Width="800"
                                       MaxWidth="800"
                                       FontSize="14">
                        <ui:AutoSuggestBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                        </ui:AutoSuggestBox.InputBindings>
                    </ui:AutoSuggestBox>
                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:AppBarButton Icon="Filter"
                                     Label="Advanced Search"
                                     Command="{Binding ShowAdvancedSearchCommand}"/>
                    <ui:AppBarButton Icon="ClearSelection"
                                     Label="Clear Filters"
                                     Command="{Binding ClearAdvancedFiltersCommand}"
                                     Visibility="{Binding ActiveFilterCount, Converter={StaticResource CountToVisibilityConverter}}"/>
                    <ui:AppBarButton Icon="Refresh"
                                     Label="Refresh"
                                     Command="{Binding RefreshCommand}"/>
                    <ui:AppBarButton Icon="Undo"
                                     Label="Reset Settings"
                                     Command="{Binding ResetSettingsCommand}"
                                     ToolTip="Clear search, filters, and selection"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid Content -->
        <Grid Grid.Row="1">
            <DataGrid x:Name="DataGrid"
                      ItemsSource="{Binding Data}"
                      SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="True"
                      CanUserSortColumns="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      ScrollViewer.ScrollChanged="OnScrollChanged"/>

            <!-- Loading Overlay -->
            <Border Background="{DynamicResource SystemControlPageBackgroundChromeMediumBrush}"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:ProgressRing IsActive="{Binding IsLoading}"
                                     Width="60"
                                     Height="60"
                                     Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding LoadingMessage}"
                               FontSize="16"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
