<UserControl x:Class="HelloID.Vault.Management.Views.Import.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,32">
            <TextBlock Text="Import Vault Data"
                      FontSize="32"
                      FontWeight="SemiBold"/>
            <TextBlock Text="Import persons, contracts, and other data from vault.json files"
                      FontSize="14"
                      Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                      Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Scrollable Content Area -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,0,24">
            <StackPanel>

        <!-- File Selection -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                          Text="Select vault.json File"
                          FontSize="16"
                          FontWeight="SemiBold"
                          Margin="0,0,0,16"/>

                <TextBox Grid.Row="1" Grid.Column="0"
                        Text="{Binding SelectedFilePath, Mode=OneWay}"
                        IsReadOnly="True"
                        ui:ControlHelper.PlaceholderText="No file selected"
                        Margin="0,0,12,0"/>

                <Button Grid.Row="1" Grid.Column="1"
                       Content="Browse..."
                       Command="{Binding SelectFileCommand}"
                       Width="120"/>
            </Grid>
        </Border>

        <!-- Primary Manager Logic Selection -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Primary Manager Logic"
                          FontSize="16"
                          FontWeight="SemiBold"
                          Margin="0,0,0,16"/>
                <TextBlock Text="Select how Primary Manager should be determined during import"
                          FontSize="13"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Content="From JSON"
                               IsChecked="{Binding SelectedPrimaryManagerLogic, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FromJson}"
                               GroupName="PrimaryManagerLogic"
                               Margin="0,0,16,0"/>
                    <RadioButton Content="Contract-Based"
                               IsChecked="{Binding SelectedPrimaryManagerLogic, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ContractBased}"
                               GroupName="PrimaryManagerLogic"
                               Margin="0,0,16,0"/>
                    <RadioButton Content="Department-Based"
                               IsChecked="{Binding SelectedPrimaryManagerLogic, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=DepartmentBased}"
                               GroupName="PrimaryManagerLogic"/>
                </StackPanel>
                <TextBlock Text="Contract-Based: Uses Primary Contract's manager | Department-Based: Uses Department manager"
                          FontSize="11"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          Margin="0,8,0,0"
                          FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Anonymization Options -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,24">
            <StackPanel>
                <CheckBox Content="Anonymize data before import"
                         IsChecked="{Binding AnonymizeBeforeImport}"
                         FontSize="16"
                         FontWeight="SemiBold"/>
                
                <TextBlock Text="Replace personal and business data with realistic fake data for GDPR compliance, testing, or demos"
                          FontSize="12"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          Margin="32,4,0,8"
                          TextWrapping="Wrap"/>

                <!-- Anonymization Settings (visible when enabled) -->
                <StackPanel Margin="32,12,0,0"
                           Visibility="{Binding AnonymizeBeforeImport, Converter={StaticResource BooleanToVisibilityConverter}}">
                    
                    <!-- Locale Information -->
                    <TextBlock Text="🌍 European names are used for anonymization (Dutch, German, French, Italian, Spanish, Polish, and more)"
                              FontSize="12"
                              Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                              Margin="0,0,0,12"
                              TextWrapping="Wrap"/>

                    <!-- Advanced Options Toggle -->
                    <ToggleButton Content="Advanced Options"
                                 IsChecked="{Binding ShowAdvancedAnonymizationOptions}"
                                 Margin="0,0,0,8"
                                 Padding="8,4"/>

                    <!-- Advanced Options Panel -->
                    <StackPanel Visibility="{Binding ShowAdvancedAnonymizationOptions, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Margin="0,8,0,0">
                        
                        <CheckBox Content="Use consistent business email domains"
                                 IsChecked="{Binding UseConsistentBusinessDomain}"
                                 Margin="0,0,0,8"/>
                        
                        <CheckBox Content="Generate unique domains per employer"
                                 IsChecked="{Binding UseMultiEmployerDomains}"
                                 Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Custom email domain:"
                                      VerticalAlignment="Center"
                                      Margin="0,0,12,0"/>
                            <TextBox Text="{Binding CustomBusinessEmailDomain, UpdateSourceTrigger=PropertyChanged}"
                                    Width="200"
                                    ui:ControlHelper.PlaceholderText="e.g., company.com"/>
                        </StackPanel>

                        <Separator Margin="0,8,0,8"/>

                         <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                             <TextBlock Text="Duplicate last names:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                             <ComboBox SelectedIndex="{Binding NameSharingMode}"
                                      Width="300">
                                 <ComboBoxItem Content="0 - Unlimited"/>
                                 <ComboBoxItem Content="1 - Unique (no duplicates)"/>
                                 <ComboBoxItem Content="2 - 1 person can share the same last name"/>
                                 <ComboBoxItem Content="3 - 2 persons can share the same last name"/>
                                 <ComboBoxItem Content="4 - 3 persons can share the same last name"/>
                                 <ComboBoxItem Content="5 - Pairs (2 people per name)"/>
                                 <ComboBoxItem Content="6 - Triples (3 people per name)"/>
                                 <ComboBoxItem Content="7 - Quadruples (4 people per name)"/>
                             </ComboBox>
                         </StackPanel>

                         <Separator Margin="0,8,0,8"/>

                         <CheckBox Content="Limit dataset for testing"
                                  IsChecked="{Binding LimitDatasetSize}"
                                  Margin="0,0,0,8"
                                  ToolTip="Import a random subset of persons for testing purposes"/>

                         <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                    Visibility="{Binding LimitDatasetSize, Converter={StaticResource BooleanToVisibilityConverter}}">
                             <TextBlock Text="Max persons:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                             <TextBox Text="{Binding MaxPersonsToImport, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60" TextAlignment="Right"/>
                             <TextBlock Text="Seed:" VerticalAlignment="Center" Margin="16,0,12,0"/>
                             <TextBox Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" ui:ControlHelper.PlaceholderText="optional"/>
                         </StackPanel>
                         <TextBlock Text="ℹ Same seed = same subset every time. Managers auto-included (not counted toward limit)."
                                   FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,0,8"
                                   Visibility="{Binding LimitDatasetSize, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   TextWrapping="Wrap"/>
                     </StackPanel>

                    <!-- Info about what gets anonymized -->
                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                           BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                           BorderThickness="1"
                           CornerRadius="4"
                           Padding="12"
                           Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Anonymized data includes:"
                                      FontSize="11"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,4"/>
                            <TextBlock FontSize="10"
                                      Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                      TextWrapping="Wrap">
                                <Run Text="• Personal: Names, emails, phones, addresses, birth dates, usernames, ExternalIds"/><LineBreak/>
                                <Run Text="• Business: Departments, locations, employers, cost centers, teams, titles"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Anonymization Progress (shown during anonymization) -->
                <StackPanel Margin="32,12,0,0"
                           Visibility="{Binding AnonymizationStatus, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding AnonymizationStatus}"
                              FontSize="12"
                              Foreground="{DynamicResource SystemControlAccentBrush}"
                              Margin="0,0,0,4"/>
                    <ui:ProgressBar Value="{Binding AnonymizationProgress}"
                                   IsIndeterminate="False"
                                   Height="4"
                                   Maximum="100"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Import Progress -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,24"
                Visibility="{Binding IsImporting, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Import Progress"
                          FontSize="16"
                          FontWeight="SemiBold"
                          Margin="0,0,0,16"/>

                <TextBlock Text="{Binding CurrentOperation}"
                          FontSize="14"
                          Margin="0,0,0,12"/>

                <ui:ProgressBar Value="{Binding ProgressPercentage}"
                               IsIndeterminate="False"
                               Height="8"
                               Margin="0,0,0,8"/>

                <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0}% complete}"
                          FontSize="12"
                          Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                          HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Import Results -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,24"
                MaxHeight="350"
                Visibility="{Binding ImportCompleted, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Import Results"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Margin="0,0,0,16"/>

                    <!-- Success/Error Message -->
                    <TextBlock Text="{Binding StatusMessage}"
                              FontSize="14"
                              FontWeight="Medium"
                              Margin="0,0,0,16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#4CAF50"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ImportResult.Success}" Value="False">
                                        <Setter Property="Foreground" Value="#F44336"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Subset Results (shown when subset was used) -->
                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12"
                            Margin="0,0,0,16"
                            Visibility="{Binding AnonymizationResult.ManagersIncluded, Converter={StaticResource IntToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12" Foreground="#2196F3">
                                <Run Text="Subset: "/>
                                <Run Text="{Binding AnonymizationResult.PersonsSelected, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" selected"/>
                                <Run Text=" + "/>
                                <Run Text="{Binding AnonymizationResult.ManagersIncluded, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" managers"/>
                                <Run Text=" = "/>
                                <Run Text="{Binding AnonymizationResult.PersonsAnonymized, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text=" total"/>
                                <Run Text=" | Seed: "/>
                                <Run Text="{Binding AnonymizationResult.SeedUsed, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Statistics Grid -->
                    <StackPanel HorizontalAlignment="Center"
                               Visibility="{Binding ImportResult.Success, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Persons:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ImportResult.PersonsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Contracts:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ImportResult.ContractsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Contacts:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ImportResult.ContactsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Departments:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ImportResult.DepartmentsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="  ↳ Auto-created:" Margin="0,0,0,8" Foreground="#FFA500"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ImportResult.DepartmentsAutoCreated}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8" Foreground="#FFA500"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Organizations:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ImportResult.OrganizationsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Locations:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ImportResult.LocationsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Employers:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ImportResult.EmployersImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Cost Centers:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ImportResult.CostCentersImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Cost Bearers:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding ImportResult.CostBearersImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Teams:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding ImportResult.TeamsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Divisions:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding ImportResult.DivisionsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Titles:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding ImportResult.TitlesImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="13" Grid.Column="0" Text="Custom Field Persons:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding ImportResult.CustomFieldPersonsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Custom Field Contracts:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding ImportResult.CustomFieldContractsImported}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="15" Grid.Column="0" Text="Empty Manager GUIDs Fixed:" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="15" Grid.Column="1" Text="{Binding ImportResult.EmptyManagerGuidsReplaced}" FontWeight="SemiBold" HorizontalAlignment="Right" Margin="0,0,0,8"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom">
            <Button Content="Import"
                   Command="{Binding StartImportCommand}"
                   Style="{StaticResource AccentButtonStyle}"
                   Width="120"
                   Margin="0,0,12,0"/>
            <Button Content="Import Company Data"
                    Command="{Binding StartCompanyImportCommand}"
                    Width="160"
                    Margin="0,0,12,0"
                    ToolTip="Import only company reference data (Departments, Locations, Cost Centers, etc.)"/>
            <Button Content="Import with Selection"
                    Command="{Binding StartPersonSelectionImportCommand}"
                    Width="150"
                    Margin="0,0,12,0"
                    ToolTip="Import company data + selected persons only"/>
            <Button Content="Reset"
                   Command="{Binding ResetCommand}"
                   Width="120"/>
        </StackPanel>
    </Grid>
</UserControl>
